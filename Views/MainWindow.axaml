<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenccNetLibGui.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:helpers="clr-namespace:OpenccNetLibGui.Helpers"
        xmlns:local="clr-namespace:OpenccNetLibGui.Constants"
        xmlns:media="using:Avalonia.Media"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="OpenccNetLibGui.Views.MainWindow"
        x:Name="MainWindowRoot"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/openccnetlib.ico"
        Title="OpenccNetLibGui"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        MinWidth="1000"
        MinHeight="300">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition />
            <RowDefinition Height="70" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Grid.Column="0" Height="70" VerticalAlignment="Bottom" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <RadioButton x:Name="RbT2S" Content="{Binding RbT2SContent}" Grid.Row="0" Grid.Column="0" FontSize="14"
                         Padding="5,0,0,0" Margin="20,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"
                         IsChecked="{Binding IsRbT2S}" GroupName="MainRb" />
            <RadioButton x:Name="RbS2T" Content="{Binding RbS2TContent}" Grid.Row="0" Grid.Column="1" FontSize="14"
                         Padding="5,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"
                         GroupName="MainRb" IsChecked="{Binding IsRbS2T}" />
            <RadioButton x:Name="RbCustom" Content="{Binding RbCustomContent}" Grid.Row="0" Grid.Column="2"
                         FontSize="14"
                         Padding="5,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" GroupName="MainRb"
                         IsChecked="{Binding IsRbCustom}" />
            <ComboBox Name="CbCustom" Grid.Column="2" Grid.Row="0" Margin="140,0,0,0" CornerRadius="6"
                      ItemsSource="{Binding CustomOptions}"
                      SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                <Interaction.Behaviors>
                    <EventTriggerBehavior EventName="GotFocus">
                        <InvokeCommandAction Command="{Binding CmbCustomGotFocusCommand}" />
                    </EventTriggerBehavior>
                </Interaction.Behaviors>
            </ComboBox>
            <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <RadioButton x:Name="RbStd" Grid.Row="0" Grid.Column="0" Content="{Binding RbStdContent}" FontSize="14"
                             Padding="5,0,0,0" Margin="20,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"
                             GroupName="SecondRb" IsChecked="{Binding IsRbStd}" />
                <RadioButton x:Name="RbZhtw" Grid.Row="0" Grid.Column="1" Content="{Binding RbZhtwContent}"
                             FontSize="14"
                             Padding="5,0,0,0" Margin="15,0,0,0" VerticalAlignment="Center"
                             HorizontalAlignment="Center"
                             GroupName="SecondRb" IsChecked="{Binding IsRbZhtw}" />
                <RadioButton x:Name="RbHk" Grid.Row="0" Grid.Column="2" Content="{Binding RbHkContent}" FontSize="14"
                             Padding="5,0,0,0" Margin="20,0,0,0" VerticalAlignment="Center"
                             HorizontalAlignment="Center" IsChecked="{Binding IsRbHk}"
                             GroupName="SecondRb" />
                <CheckBox x:Name="CbZhtw" Grid.Row="0" Grid.Column="3" Content="{Binding CbZhtwContent}" FontSize="13"
                          Padding="5,0,0,0" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left"
                          IsChecked="{Binding IsCbZhtw}" IsEnabled="{Binding IsCbZhtwEnabled}"
                          ToolTip.Tip="{Binding CbZhtwHint}" />
                <CheckBox x:Name="CbPunctuation" Grid.Row="0" Grid.Column="4" Content="{Binding CbPunctuationContent}"
                          FontSize="13" Padding="5,0,0,0" Margin="5,0,0,0" VerticalAlignment="Center"
                          HorizontalAlignment="Left" IsChecked="{Binding IsCbPunctuation}"
                          ToolTip.Tip="{Binding CbPunctuationHint}" />
            </Grid>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <TabControl Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Grid.RowSpan="2" Margin="10,0,10,0">
                <TabItem x:Name="TabMain" IsSelected="{Binding IsTabMain}"
                         FontSize="14" FontWeight="{Binding TabMainFontWeight}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Classes="icon-font"
                                       Text="{x:Static local:Icons.Sync}" />
                            <TextBlock Text="{Binding TabMainContent}" />
                        </StackPanel>
                    </TabItem.Header>
                    <!-- <Grid Background="#FFE5E5E5"> -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <!-- <Border Grid.Row="0" Grid.Column="0" -->
                        <!--         Margin="5" -->
                        <!--         BorderThickness="3" -->
                        <!--         CornerRadius="6" -->
                        <!--         BorderBrush="DarkGray"> -->
                        <!-- 左邊 Source -->
                        <Border Grid.Row="0" Grid.Column="0"
                                Margin="8,8,4,4"
                                Classes="editor-container">
                            <avaloniaEdit:TextEditor
                                x:Name="TbSource"
                                BorderThickness="0"
                                Background="{DynamicResource ThemeBackgroundBrush}"
                                Foreground="{DynamicResource ThemeForegroundBrush}"
                                Document="{Binding TbSourceTextDocument, Mode=TwoWay}"
                                FontFamily="{Binding EditorFontFamily}"
                                FontSize="{Binding EditorFontSize}"
                                ShowLineNumbers="True"
                                WordWrap="True"
                                VerticalScrollBarVisibility="Visible"
                                TextChanged="TbSource_TextChanged">
                                <Interaction.Behaviors>
                                    <helpers:TextEditorSelectionBehavior
                                        SelectionStart="{Binding TbSourceSelectionStart, Mode=TwoWay}"
                                        SelectionLength="{Binding TbSourceSelectionLength, Mode=TwoWay}"
                                        CaretOffset="{Binding TbSourceCaretOffset, Mode=TwoWay}" />
                                </Interaction.Behaviors>
                                <avaloniaEdit:TextEditor.ContextMenu>
                                    <ContextMenu>
                                        <ContextMenu.Styles>
                                            <!-- 所有 class="section-header" 嘅 MenuItem 用呢個樣式 -->
                                            <Style Selector="MenuItem.section-header">
                                                <Setter Property="IsEnabled" Value="False" />
                                                <Setter Property="FontWeight" Value="Bold" />
                                                <Setter Property="Foreground" Value="Gray" />
                                                <Setter Property="Padding" Value="8,4" />
                                                <Setter Property="Background" Value="#F7F7F7" />
                                            </Style>
                                        </ContextMenu.Styles>
                                        <!-- 🔹 Section: PDF Options -->
                                        <MenuItem IsEnabled="False" Classes="section-header">
                                            <MenuItem.Header>
                                                <TextBlock
                                                    Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).PdfOptionsContent, FallbackValue=''}"
                                                    Foreground="Gray"
                                                    FontWeight="Bold"
                                                    LetterSpacing="0.5"
                                                    Padding="8,4" />
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <!-- 📝 Convert filename -->
                                        <!-- IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsCbConvertFilename, Mode=TwoWay}"> -->
                                        <MenuItem ToggleType="CheckBox"
                                                  IsChecked="{Binding DataContext.IsCbConvertFilename, ElementName=MainWindowRoot, Mode=TwoWay, FallbackValue=false}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="📝" />
                                                    <TextBlock
                                                        Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).ConvertFilenameContent, FallbackValue=''}" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <!-- 📄 Add page header -->
                                        <MenuItem ToggleType="CheckBox"
                                                  IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsAddPdfPageHeader, Mode=TwoWay, FallbackValue=false}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="📄" />
                                                    <TextBlock
                                                        Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).AddPdfPageHeaderContent, FallbackValue=''}" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <!-- 🔧 Compact PDF text -->
                                        <MenuItem ToggleType="CheckBox"
                                                  IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsCompactPdfText, Mode=TwoWay, FallbackValue=false}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="🔧" />
                                                    <TextBlock
                                                        Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).CompactPdfTextContent, FallbackValue=''}" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <!-- 🔃 Auto-Reflow PDF text -->
                                        <MenuItem ToggleType="CheckBox"
                                                  IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsAutoReflow, Mode=TwoWay, FallbackValue=true}"
                                                  ToolTip.Tip="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).AutoReflowPdfTextHint, FallbackValue=''}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="🔃" />
                                                    <TextBlock
                                                        Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).AutoReflowPdfTextContent, FallbackValue=''}" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <!-- 🛡️ Ignore untrusted / overlay PDF text -->
                                        <MenuItem ToggleType="CheckBox"
                                                  IsEnabled="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).CanIgnoreUntrustedPdfText, FallbackValue=false}"
                                                  IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsIgnoreUntrustedPdfText, Mode=TwoWay, FallbackValue=false}"
                                                  ToolTip.Tip="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IgnoreUntrustedPdfTextHint, FallbackValue=''}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="🛡️" />
                                                    <TextBlock
                                                        Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IgnoreUntrustedPdfTextContent, FallbackValue=''}" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <!-- Separator -->
                                        <Separator />

                                        <!-- 🔹 Section: PDF Engine -->
                                        <MenuItem IsEnabled="False" Classes="section-header">
                                            <MenuItem.Header>
                                                <TextBlock
                                                    Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).PdfEngineContent, FallbackValue=''}"
                                                    Foreground="Gray"
                                                    FontWeight="Bold"
                                                    LetterSpacing="0.5"
                                                    Padding="8,4" />
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <!-- ⚙️ Use PdfPig engine -->
                                        <MenuItem ToggleType="Radio"
                                                  IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsPdfPigEngine, Mode=TwoWay, FallbackValue=false}"
                                                  ToolTip.Tip="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).UsePdfPigEngineHint, FallbackValue=''}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="⚙️" />
                                                    <TextBlock
                                                        Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).UsePdfPigEngineContent, FallbackValue=''}" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <!-- ⚙️ Use Pdfium engine -->
                                        <MenuItem ToggleType="Radio"
                                                  IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsPdfiumEngine, Mode=TwoWay, FallbackValue=true}"
                                                  ToolTip.Tip="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).UsePdfiumEngineHint, FallbackValue=''}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="⚙️" />
                                                    <TextBlock
                                                        Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).UsePdfiumEngineContent, FallbackValue=''}" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <!-- Separator -->
                                        <Separator />

                                        <!-- 🔹 Section: Heading rules -->
                                        <MenuItem IsEnabled="False" Classes="section-header">
                                            <MenuItem.Header>
                                                <TextBlock
                                                    Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).HeadingRulesContent, FallbackValue=''}"
                                                    Foreground="Gray"
                                                    FontWeight="Bold"
                                                    LetterSpacing="0.5"
                                                    Padding="8,4" />
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <!-- ✏️ Short heading settings -->
                                        <MenuItem Command="{Binding ShowShortHeadingDialogCommand}"
                                                  ToolTip.Tip="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).ShortHeadingSettingsHint, FallbackValue=''}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="✏️" />
                                                    <TextBlock
                                                        Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).ShortHeadingSettingsContent, FallbackValue=''}" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <Separator />

                                        <!-- 💾 Save advanced settings -->
                                        <MenuItem Command="{Binding SaveLanguageSettingsCommand}"
                                                  IsEnabled="{Binding IsSettingsDirty}"
                                                  ToolTip.Tip="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).SaveAdvancedSettingsHint, FallbackValue=''}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Save}" />
                                                    <TextBlock
                                                        Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).BtnSaveAdvancedSettingsContent, FallbackValue=''}" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>

                                        <!-- Separator -->
                                        <Separator Margin="0,6"
                                                   Background="{DynamicResource SystemControlForegroundBaseLowBrush}" />

                                        <!-- 🔹 Section: About -->
                                        <MenuItem Command="{Binding ShowAboutDialog}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="ℹ️" />
                                                    <TextBlock Text="About…" />
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>

                                    </ContextMenu>
                                </avaloniaEdit:TextEditor.ContextMenu>
                            </avaloniaEdit:TextEditor>
                        </Border>

                        <!-- <Border Grid.Row="0" Grid.Column="1" -->
                        <!--         Margin="5" -->
                        <!--         BorderThickness="3" -->
                        <!--         CornerRadius="6" -->
                        <!--         BorderBrush="DarkGray"> -->
                        <!-- 右邊 Destination -->
                        <Border Grid.Row="0" Grid.Column="1"
                                Margin="4,8,8,4"
                                Classes="editor-container">
                            <avaloniaEdit:TextEditor
                                x:Name="TbDestination"
                                BorderThickness="0"
                                Background="{DynamicResource ThemeBackgroundBrush}"
                                Foreground="{DynamicResource ThemeForegroundBrush}"
                                Document="{Binding TbDestinationTextDocument}"
                                FontFamily="{Binding EditorFontFamily}"
                                FontSize="{Binding EditorFontSize}"
                                ShowLineNumbers="True"
                                WordWrap="True"
                                VerticalScrollBarVisibility="Visible"
                                IsReadOnly="True" />
                        </Border>

                        <Label Grid.Row="1" Grid.Column="0" Content="{Binding SourceContent}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center" Margin="5,0,0,0" FontSize="16" BorderBrush="DarkGray"
                               BorderThickness="3,0,0,2" />
                        <Label x:Name="LblSourceCode" Grid.Row="1" Grid.Column="0"
                               Content="{Binding LblSourceCodeContent}"
                               HorizontalAlignment="Left" VerticalAlignment="Center" Margin="70,0,0,0" FontSize="16" />
                        <Label x:Name="LblTotalChars" Grid.Row="1" Grid.Column="0"
                               Content="{Binding LblTotalCharsContent}" HorizontalAlignment="Right"
                               VerticalAlignment="Center" Margin="0,0,175,0" FontSize="14" />
                        <Button x:Name="BthReflow" Grid.Row="1" Grid.Column="0" Padding="0 2" Width="40"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                Margin="0,2,135,0" FontSize="14" FontWeight="Bold"
                                ToolTip.Tip="{Binding ReflowHint}"
                                Command="{Binding BtnReflowCommand}">
                            <StackPanel Orientation="Horizontal">
                                <!-- <controls:SymbolIcon Symbol="Refresh" FontSize="20" /> -->
                                <!-- <PathIcon Classes="toolbar-icon" -->
                                <!--           Data="{StaticResource Icon.Refresh}"> -->
                                <!--     <PathIcon.RenderTransform> -->
                                <!--         <ScaleTransform ScaleX="0.8" ScaleY="0.8"/> -->
                                <!--     </PathIcon.RenderTransform> -->
                                <!-- </PathIcon> -->
                                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Refresh}" />
                            </StackPanel>
                        </Button>
                        <Label Grid.Column="1" Content="{Binding DestinationContent}" HorizontalAlignment="Left"
                               Margin="5,0,0,0"
                               Grid.Row="1" VerticalAlignment="Center" FontSize="16" BorderBrush="DarkGray"
                               BorderThickness="3,0,0,2" />
                        <Label x:Name="LblDestinationCode" Grid.Column="1"
                               Content="{Binding LblDestinationCodeContent}" HorizontalAlignment="Left"
                               Margin="110,0,0,0" Grid.Row="1" VerticalAlignment="Center" FontSize="16" />
                        <Button x:Name="BtnClearSource" Padding="0 2" Width="40"
                                HorizontalAlignment="Right" HorizontalContentAlignment="Center"
                                Margin="0,2,90,0" Grid.Row="1" ToolTip.Tip="{Binding ClearSourceHint}"
                                Grid.Column="0" VerticalAlignment="Center" FontSize="14"
                                Command="{Binding BtnClearTbSourceCommand}"
                                FontWeight="Bold">
                            <!-- <controls:SymbolIcon Symbol="Delete" FontSize="20" /> -->
                            <!-- <PathIcon Classes="toolbar-icon" -->
                            <!--           Data="{StaticResource Icon.Delete}"> -->
                            <!--     <PathIcon.RenderTransform> -->
                            <!--         <ScaleTransform ScaleX="0.8" ScaleY="0.8"/> -->
                            <!--     </PathIcon.RenderTransform> -->
                            <!-- </PathIcon> -->
                            <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Delete}" />
                        </Button>
                        <Button x:Name="BtnPaste" Padding="5 2" Width="80" HorizontalAlignment="Right"
                                HorizontalContentAlignment="Center" FontWeight="SemiBold"
                                Margin="0,2,5,0" Grid.Row="1" Height="28"
                                Grid.Column="0" VerticalAlignment="Center" FontSize="14"
                                Command="{Binding BtnPasteCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <!-- <controls:SymbolIcon Symbol="Paste" FontSize="20" /> -->
                                <!-- <PathIcon Classes="toolbar-icon" -->
                                <!--           Data="{StaticResource Icon.Paste}"> -->
                                <!--     <PathIcon.RenderTransform> -->
                                <!--         <ScaleTransform ScaleX="0.75" ScaleY="0.75"/> -->
                                <!--     </PathIcon.RenderTransform> -->
                                <!-- </PathIcon> -->
                                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Paste}" />
                                <TextBlock Text="{Binding BtnPasteContent}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnClearDestination" Grid.Column="1" Padding="0 2" Width="40"
                                HorizontalAlignment="Right" HorizontalContentAlignment="Center" Margin="0,2,90,0"
                                Grid.Row="1" VerticalAlignment="Center" ToolTip.Tip="{Binding ClearDestinationHint}"
                                FontSize="14" Command="{Binding BtnClearTbDestinationCommand}" FontWeight="Bold">
                            <!-- <controls:SymbolIcon Symbol="Delete" FontSize="20" /> -->
                            <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Delete}" />
                        </Button>
                        <Button x:Name="BtnCopy" Grid.Column="1" Padding="5 2" Width="80"
                                HorizontalAlignment="Right" HorizontalContentAlignment="Center" Margin="0,2,5,0"
                                Grid.Row="1" VerticalAlignment="Center" FontWeight="SemiBold"
                                FontSize="14" Command="{Binding BtnCopyCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <!-- <controls:SymbolIcon Symbol="Copy" FontSize="20" /> -->
                                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Copy}" />
                                <TextBlock Text="{Binding BtnCopyContent}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </TabItem>
                <TabItem x:Name="TabBatch" IsSelected="{Binding IsTabBatch}" FontSize="14"
                         FontWeight="{Binding TabBatchFontWeight}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Classes="icon-font"
                                       Text="{x:Static local:Icons.MoveToFolder}" />
                            <TextBlock Text="{Binding TabBatchContent}" />
                        </StackPanel>
                    </TabItem.Header>
                    <!-- <Grid Background="#FFE5E5E5"> -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <ListBox x:Name="LbxSource" Grid.Row="0" Grid.Column="0" Margin="5,5,5,0"
                                 BorderThickness="2,2,2,2" ItemsSource="{Binding LbxSourceItems}"
                                 SelectedIndex="{Binding LbxSourceSelectedIndex, Mode=TwoWay}"
                                 SelectedItem="{Binding LbxSourceSelectedItem, Mode=TwoWay}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <ContextMenu.Styles>
                                        <!-- 所有 class="section-header" 嘅 MenuItem 用呢個樣式 -->
                                        <Style Selector="MenuItem.section-header">
                                            <Setter Property="IsEnabled" Value="False" />
                                            <Setter Property="FontWeight" Value="Bold" />
                                            <Setter Property="Foreground" Value="Gray" />
                                            <Setter Property="Padding" Value="8,4" />
                                            <Setter Property="Background" Value="#F7F7F7" />
                                        </Style>
                                    </ContextMenu.Styles>
                                    <!-- 🔹 Section: PDF Options -->
                                    <MenuItem IsEnabled="False" Classes="section-header">
                                        <MenuItem.Header>
                                            <TextBlock
                                                Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).PdfOptionsContent, FallbackValue=''}"
                                                Foreground="Gray"
                                                FontWeight="Bold"
                                                LetterSpacing="0.5"
                                                Padding="8,4" />
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <!-- 📝 Convert filename -->
                                    <MenuItem ToggleType="CheckBox"
                                              IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsCbConvertFilename, Mode=TwoWay, FallbackValue=false}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="📝" />
                                                <TextBlock
                                                    Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).ConvertFilenameContent, FallbackValue=''}" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <!-- 📄 Add page header -->
                                    <MenuItem ToggleType="CheckBox"
                                              IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsAddPdfPageHeader, Mode=TwoWay, FallbackValue=false}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="📄" />
                                                <TextBlock
                                                    Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).AddPdfPageHeaderContent, FallbackValue=''}" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <!-- 🔧 Compact PDF text -->
                                    <MenuItem ToggleType="CheckBox"
                                              IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsCompactPdfText, Mode=TwoWay, FallbackValue=false}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="🔧" />
                                                <TextBlock
                                                    Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).CompactPdfTextContent, FallbackValue=''}" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <!-- 🔃 Auto-Reflow PDF text -->
                                    <MenuItem ToggleType="CheckBox"
                                              ToolTip.Tip="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).AutoReflowPdfTextHint, FallbackValue=''}"
                                              IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsAutoReflow, Mode=TwoWay, FallbackValue=true}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="🔃" />
                                                <TextBlock
                                                    Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).AutoReflowPdfTextContent, FallbackValue=''}" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <!-- 🛡️ Ignore untrusted / overlay PDF text -->
                                    <MenuItem ToggleType="CheckBox"
                                              IsEnabled="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).CanIgnoreUntrustedPdfText, FallbackValue=false}"
                                              IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsIgnoreUntrustedPdfText, Mode=TwoWay, FallbackValue=false}"
                                              ToolTip.Tip="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IgnoreUntrustedPdfTextHint, FallbackValue=''}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="🛡️" />
                                                <TextBlock
                                                    Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IgnoreUntrustedPdfTextContent, FallbackValue=''}" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <!-- Separator -->
                                    <Separator />

                                    <!-- 🔹 Section: PDF Engine -->
                                    <MenuItem IsEnabled="False" Classes="section-header">
                                        <MenuItem.Header>
                                            <TextBlock
                                                Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).PdfEngineContent, FallbackValue=''}"
                                                Foreground="Gray"
                                                FontWeight="Bold"
                                                LetterSpacing="0.5"
                                                Padding="8,4" />
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <!-- ⚙️ Use PdfPig engine -->
                                    <MenuItem ToggleType="Radio"
                                              IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsPdfPigEngine, Mode=TwoWay, FallbackValue=false}"
                                              ToolTip.Tip="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).UsePdfPigEngineHint, FallbackValue=''}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="⚙️" />
                                                <TextBlock
                                                    Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).UsePdfPigEngineContent, FallbackValue=''}" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <!-- ⚙️ Use Pdfium engine -->
                                    <MenuItem ToggleType="Radio"
                                              IsChecked="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).IsPdfiumEngine, Mode=TwoWay, FallbackValue=true}"
                                              ToolTip.Tip="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).UsePdfiumEngineHint, FallbackValue=''}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="⚙️" />
                                                <TextBlock
                                                    Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).UsePdfiumEngineContent, FallbackValue=''}" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <!-- Separator -->
                                    <Separator />

                                    <!-- 🔹 Section: Heading rules -->
                                    <MenuItem IsEnabled="False" Classes="section-header">
                                        <MenuItem.Header>
                                            <TextBlock
                                                Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).HeadingRulesContent, FallbackValue=''}"
                                                Foreground="Gray"
                                                FontWeight="Bold"
                                                LetterSpacing="0.5"
                                                Padding="8,4" />
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <!-- ✏️ Short heading settings -->
                                    <MenuItem Command="{Binding ShowShortHeadingDialogCommand}"
                                              ToolTip.Tip="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).ShortHeadingSettingsHint, FallbackValue=''}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="✏️" />
                                                <TextBlock
                                                    Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).ShortHeadingSettingsContent, FallbackValue=''}" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <Separator />

                                    <!-- 💾 Save advanced settings -->
                                    <MenuItem Command="{Binding SaveLanguageSettingsCommand}"
                                              IsEnabled="{Binding IsSettingsDirty}"
                                              ToolTip.Tip="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).SaveAdvancedSettingsHint, FallbackValue=''}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Save}" />
                                                <TextBlock
                                                    Text="{Binding #MainWindowRoot.((vm:MainWindowViewModel)DataContext).BtnSaveAdvancedSettingsContent, FallbackValue=''}" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>

                                    <!-- Separator -->
                                    <Separator Margin="0,6"
                                               Background="{DynamicResource SystemControlForegroundBaseLowBrush}" />

                                    <!-- 🔹 Section: About -->
                                    <MenuItem Command="{Binding ShowAboutDialog}">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="ℹ️" />
                                                <TextBlock Text="About…" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>

                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                        <Label Grid.Row="1" Grid.Column="0" Content="{Binding SourceContent}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center" Margin="5,0,0,0" FontSize="16" BorderBrush="DarkGray"
                               BorderThickness="3,0,0,2" />

                        <TabControl Grid.Row="0" Grid.Column="1" TabStripPlacement="Bottom">
                            <TabItem x:Name="TabMessage" FontSize="14"
                                     IsSelected="{Binding IsTabMessage}"
                                     FontWeight="Medium">
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="3">
                                        <TextBlock Classes="icon-font"
                                                   Text="{x:Static local:Icons.Message}" />
                                        <TextBlock Text="{Binding TabMessageContent}" />
                                    </StackPanel>
                                </TabItem.Header>
                                <Grid>
                                    <ListBox x:Name="LbxDestination" Grid.Row="0" Grid.Column="0" Margin="0,5,0,0"
                                             BorderThickness="2,2,2,2" ItemsSource="{Binding LbxDestinationItems}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        <!-- LOG ListBox auto-scroll view to last item -->
                                        <Interaction.Behaviors>
                                            <helpers:AutoScrollBehavior />
                                        </Interaction.Behaviors>
                                    </ListBox>
                                </Grid>
                            </TabItem>
                            <TabItem x:Name="TabPreview" FontSize="14" FontWeight="Medium"
                                     IsSelected="{Binding IsTabPreview}">
                                <TabItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="3">
                                        <TextBlock Classes="icon-font"
                                                   Text="{x:Static local:Icons.Preview}" />
                                        <TextBlock Text="{Binding TabPreviewContent}" />
                                    </StackPanel>
                                </TabItem.Header>
                                <Grid>
                                    <!-- <TextBox x:Name="TbPreview" Grid.Row="0" Grid.Column="0" Margin="0,5,0,0" -->
                                    <!--          BorderThickness="2,2,2,2" FontSize="16" IsReadOnly="True" -->
                                    <!--          FontFamily="Noto Sans SC" -->
                                    <!--          TextWrapping="Wrap" Text="{Binding TbPreviewText}" /> -->
                                    <avaloniaEdit:TextEditor x:Name="TbPreview"
                                                             Grid.Row="0" Grid.Column="0"
                                                             Margin="0,5,0,0"
                                                             BorderThickness="2"
                                                             BorderBrush="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"
                                                             Document="{Binding TbPreviewTextDocument}"
                                                             WordWrap="True"
                                                             VerticalScrollBarVisibility="Visible"
                                                             ShowLineNumbers="False"
                                                             FontFamily="{Binding EditorFontFamily}"
                                                             FontSize="{Binding EditorFontSize}"
                                                             IsReadOnly="True" />
                                </Grid>
                            </TabItem>
                        </TabControl>

                        <Label Grid.Column="1" Content="{Binding OutputContent}" HorizontalAlignment="Left"
                               Margin="5,0,0,0"
                               Grid.Row="1" VerticalAlignment="Center" FontSize="16" BorderBrush="DarkGray"
                               BorderThickness="3,0,0,2" />
                        <Button x:Name="BtnAdd" Padding="0 2" Width="50" HorizontalAlignment="Left"
                                HorizontalContentAlignment="Center" ToolTip.Tip="{Binding AddFileHint}"
                                Margin="70,2,0,2" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                FontSize="20" Command="{Binding BtnAddCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.AddTo}" />
                            </StackPanel>
                            <!-- <PathIcon Classes="toolbar-icon" Data="{StaticResource Icon.Add}" /> -->
                        </Button>
                        <Button x:Name="BtnRemove" Padding="0 2" Width="50" HorizontalAlignment="Left"
                                HorizontalContentAlignment="Center" Margin="125,2,0,2"
                                Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                FontSize="20" ToolTip.Tip="{Binding RemoveFileHint}"
                                Command="{Binding BtnRemoveCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.RemoveFrom}" />
                            </StackPanel>
                            <!-- <PathIcon Classes="toolbar-icon" Data="{StaticResource Icon.Remove}" /> -->
                        </Button>
                        <CheckBox x:Name="CbConvertFilename" Grid.Row="1" Grid.Column="0"
                                  Content="{Binding FilenameContent}"
                                  FontSize="13" FontWeight="SemiBold" Padding="5,0" Margin="180,2,0,2"
                                  VerticalAlignment="Center"
                                  ToolTip.Tip="{Binding ConvertFilenameHint}"
                                  HorizontalAlignment="Left" IsChecked="{Binding IsCbConvertFilename}" />
                        <Button x:Name="BtnPreview" Content="{Binding BtnPreviewContent}" Padding="0 2" Width="70"
                                HorizontalAlignment="Right" HorizontalContentAlignment="Center" Margin="0,2,135,2"
                                Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Height="26"
                                ToolTip.Tip="{Binding PreviewHint}"
                                VerticalAlignment="Center" FontSize="14" Command="{Binding BtnPreviewCommand}" />
                        <Button x:Name="BtnDetect" Content="{Binding BtnDetectContent}" Padding="0 2" Width="70"
                                HorizontalAlignment="Right" HorizontalContentAlignment="Center" Margin="0,2,60,2"
                                Grid.Row="1" Grid.Column="0" FontWeight="SemiBold" Height="26"
                                ToolTip.Tip="{Binding DetectHint}"
                                VerticalAlignment="Center" FontSize="14" Command="{Binding BtnDetectCommand}" />
                        <Button x:Name="BtnClear" Padding="0 2" Width="50" HorizontalAlignment="Right"
                                HorizontalContentAlignment="Center" ToolTip.Tip="{Binding ClearSourceListHint}"
                                Margin="0,2,5,2" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontSize="14"
                                FontWeight="Bold" Command="{Binding BtnClearLbxSourceCommand}">
                            <StackPanel Orientation="Horizontal">
                                <!-- <controls:SymbolIcon Symbol="Delete" FontSize="20" /> -->
                                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Delete}" />
                            </StackPanel>
                        </Button>
                        <TextBox x:Name="TbOutFolder" Grid.Row="1" Grid.Column="1" Width="290"
                                 Text="{Binding TbOutFolderText}"
                                 HorizontalAlignment="Left" VerticalAlignment="Center"
                                 helpers:FocusAttachedProperty.IsFocused="{Binding IsTbOutFolderFocus}"
                                 VerticalContentAlignment="Center" Margin="75,2,2,2" Padding="0 2" />
                        <Button x:Name="BtnOutFolder" Padding="0 2" Width="50" HorizontalAlignment="Right"
                                HorizontalContentAlignment="Center" ToolTip.Tip="{Binding SelectOutputFolderHint}"
                                Margin="0,2,60,2" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" FontSize="14"
                                FontWeight="Bold" Command="{Binding BtnSelectOutFolderCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.FolderOpen}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnOutClear" Padding="0 2" Width="50" HorizontalAlignment="Right"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Height="26"
                                Margin="0,2,5,2" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" FontSize="14"
                                ToolTip.Tip="{Binding ClearDisplayHint}"
                                FontWeight="Bold" Command="{Binding BtnMessagePreviewClearCommand}">
                            <StackPanel Orientation="Horizontal">
                                <!-- <controls:SymbolIcon Symbol="Delete" FontSize="20" /> -->
                                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Delete}" />
                            </StackPanel>
                        </Button>

                    </Grid>
                </TabItem>
                <TabItem x:Name="TabSettings" IsSelected="{Binding IsTabSettings}" FontSize="14"
                         FontWeight="{Binding TabSettingsFontWeight}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Classes="icon-font"
                                       Text="{x:Static local:Icons.Settings}" />
                            <TextBlock Text="{Binding TabSettingsContent}" />
                        </StackPanel>
                    </TabItem.Header>
                    <Border Margin="8"
                            Padding="18"
                            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                            BorderThickness="2"
                            CornerRadius="6">
                        <Grid RowDefinitions="*,Auto">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Spacing="18"
                                            Margin="0,0,18,0">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding ConversionSettingsContent}"
                                                   FontSize="16"
                                                   FontWeight="Bold" />
                                        <CheckBox Content="{Binding ConvertFilenameContent}"
                                                  FontSize="14"
                                                  IsChecked="{Binding IsCbConvertFilename, Mode=TwoWay}"
                                                  ToolTip.Tip="{Binding ConvertFilenameHint}" />
                                        <Grid ColumnDefinitions="220,100"
                                              RowDefinitions="Auto,Auto"
                                              ColumnSpacing="8"
                                              RowSpacing="4"
                                              Margin="0,8,0,0">
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Margin="0,0,0,2"
                                                       Text="{Binding EditorFontContent}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="1"
                                                       Margin="0,0,0,2"
                                                       Text="{Binding EditorFontSizeContent}"
                                                       FontWeight="SemiBold" />
                                            <ComboBox Width="220"
                                                      Grid.Row="1"
                                                      Grid.Column="0"
                                                      ItemsSource="{Binding SystemFonts}"
                                                      SelectedItem="{Binding EditorFontFamily, Mode=TwoWay}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate x:DataType="media:FontFamily">
                                                        <TextBlock Text="{Binding Name}" FontFamily="{Binding}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <NumericUpDown Grid.Row="1"
                                                           Grid.Column="1"
                                                           Width="100"
                                                           Minimum="8"
                                                           Maximum="72"
                                                           Increment="1"
                                                           Value="{Binding EditorFontSizeValue, Mode=TwoWay}" />
                                        </Grid>
                                    </StackPanel>

                                    <Separator />

                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding UiLanguageContent}"
                                                   FontSize="16"
                                                   FontWeight="Bold" />
                                        <Grid ColumnDefinitions="*,*">
                                            <ComboBox SelectedIndex="{Binding SelectedUiLanguageIndex, Mode=TwoWay}"
                                                      Width="220"
                                                      HorizontalAlignment="Left"
                                                      FontSize="14">
                                                <ComboBoxItem Content="{Binding UiLanguageOption0Content}" />
                                                <ComboBoxItem Content="{Binding UiLanguageOption1Content}" />
                                                <ComboBoxItem Content="{Binding UiLanguageOption2Content}" />
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>

                                    <Separator />

                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding ThemeModeContent}"
                                                   FontSize="16"
                                                   FontWeight="Bold" />
                                        <Grid ColumnDefinitions="*,*">
                                            <ComboBox SelectedIndex="{Binding SelectedThemeModeIndex, Mode=TwoWay}"
                                                      Width="220"
                                                      HorizontalAlignment="Left"
                                                      FontSize="14"
                                                      ToolTip.Tip="{Binding ThemeModeHint}">
                                                <ComboBoxItem Content="{Binding ThemeModeOption0Content}" />
                                                <ComboBoxItem Content="{Binding ThemeModeOption1Content}" />
                                                <ComboBoxItem Content="{Binding ThemeModeOption2Content}" />
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>

                                    <Separator />

                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding PdfOptionsContent}"
                                                   FontSize="16"
                                                   FontWeight="Bold" />
                                        <CheckBox Content="{Binding AddPdfPageHeaderContent}"
                                                  FontSize="14"
                                                  IsChecked="{Binding IsAddPdfPageHeader, Mode=TwoWay}" />
                                        <CheckBox Content="{Binding CompactPdfTextContent}"
                                                  FontSize="14"
                                                  IsChecked="{Binding IsCompactPdfText, Mode=TwoWay}" />
                                        <CheckBox Content="{Binding AutoReflowPdfTextContent}"
                                                  FontSize="14"
                                                  IsChecked="{Binding IsAutoReflow, Mode=TwoWay}"
                                                  ToolTip.Tip="{Binding AutoReflowPdfTextHint}" />
                                        <CheckBox Content="{Binding IgnoreUntrustedPdfTextContent}"
                                                  FontSize="14"
                                                  IsEnabled="{Binding CanIgnoreUntrustedPdfText}"
                                                  IsChecked="{Binding IsIgnoreUntrustedPdfText, Mode=TwoWay}"
                                                  ToolTip.Tip="{Binding IgnoreUntrustedPdfTextHint}" />
                                    </StackPanel>

                                    <Separator />

                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding PdfEngineContent}"
                                                   FontSize="16"
                                                   FontWeight="Bold" />
                                        <RadioButton Content="{Binding UsePdfPigEngineContent}"
                                                     FontSize="14"
                                                     GroupName="SettingsPdfEngine"
                                                     IsChecked="{Binding IsPdfPigEngine, Mode=TwoWay}"
                                                     ToolTip.Tip="{Binding UsePdfPigEngineHint}" />
                                        <RadioButton Content="{Binding UsePdfiumEngineContent}"
                                                     FontSize="14"
                                                     GroupName="SettingsPdfEngine"
                                                     IsChecked="{Binding IsPdfiumEngine, Mode=TwoWay}"
                                                     ToolTip.Tip="{Binding UsePdfiumEngineHint}" />
                                    </StackPanel>

                                    <Separator />

                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding HeadingRulesContent}"
                                                   FontSize="16"
                                                   FontWeight="Bold" />
                                        <Button HorizontalAlignment="Left"
                                                Height="34"
                                                Padding="12,0"
                                                Command="{Binding ShowShortHeadingDialogCommand}"
                                                ToolTip.Tip="{Binding ShortHeadingSettingsHint}">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Edit}" />
                                                <TextBlock Text="{Binding ShortHeadingSettingsContent}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <Grid Grid.Row="1"
                                  ColumnDefinitions="*,Auto"
                                  Margin="0,16,0,0"
                                  ColumnSpacing="16"
                                  VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Edit}"
                                               IsVisible="{Binding IsSettingsDirty}" />
                                    <TextBlock Text="{Binding UnsavedChangesContent}"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsSettingsDirty}" />
                                    <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Completed}"
                                               Opacity="0.8"
                                               IsVisible="{Binding !IsSettingsDirty}" FontSize="22" />
                                    <TextBlock Text="{Binding AllSettingsSavedContent}"
                                               Opacity="0.8"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding !IsSettingsDirty}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        MinWidth="180"
                                        Height="36"
                                        Padding="14,0"
                                        HorizontalAlignment="Right"
                                        Command="{Binding SaveLanguageSettingsCommand}"
                                        IsEnabled="{Binding IsSettingsDirty}"
                                        ToolTip.Tip="{Binding SaveAdvancedSettingsHint}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Save}" />
                                        <TextBlock Text="{Binding BtnSaveAdvancedSettingsContent}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
        <!-- <Button x:Name="BtnProcess" Content="Process" Padding="0 2" Width="100" HorizontalAlignment="Center" -->
        <!--         HorizontalContentAlignment="Center" IsVisible="{Binding IsBtnProcessVisible}" -->
        <!--         Margin="0,0,0,0" Grid.Row="2" VerticalAlignment="Center" FontSize="18" FontWeight="Bold" -->
        <!--         Command="{Binding BtnProcessCommand}" Foreground="RoyalBlue" /> -->
        <Button x:Name="BtnProcess"
                Padding="6,6,12, 6"
                Grid.Row="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsVisible="{Binding IsBtnProcessVisible}"
                Command="{Binding BtnProcessCommand}"
                Classes="accent-button">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <!-- <controls:SymbolIcon Symbol="Play" FontSize="22" /> -->
                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Play}" FontSize="22" />
                <TextBlock Text="{Binding ProcessContent}" />
            </StackPanel>
        </Button>

        <!-- <Button x:Name="BtnBatchStart" Content="Batch Start" Padding="0 2" Width="120" HorizontalAlignment="Center" -->
        <!--         HorizontalContentAlignment="Center" Foreground="RoyalBlue" -->
        <!--         Margin="0,0,0,0" Grid.Row="2" VerticalAlignment="Center" FontSize="18" FontWeight="Bold" -->
        <!--         IsVisible="{Binding IsBtnBatchStartVisible}" Command="{Binding BtnBatchStartCommand}" /> -->
        <Button x:Name="BtnBatchStart"
                Padding="6,6,12, 6"
                Grid.Row="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                IsVisible="{Binding IsBtnBatchStartVisible}"
                Command="{Binding BtnBatchStartCommand}"
                Classes="accent-button">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <!-- <controls:SymbolIcon Symbol="Play" FontSize="22" /> -->
                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.Play}" FontSize="22" />
                <TextBlock Text="{Binding BatchStartContent}" />
            </StackPanel>
        </Button>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="10"
                    Margin="20,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

            <Button x:Name="BtnOpenFile"
                    Padding="5 2"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    IsVisible="{Binding IsBtnOpenFileVisible}"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Height="30"
                    ToolTip.Tip="{Binding OpenFileHint}"
                    Command="{Binding BtnOpenFileCommand}"
                    Classes="outline-button">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <TextBlock Classes="icon-font" Text="{x:Static local:Icons.OpenFile}" />
                    <TextBlock Text="{Binding BtnOpenFileContent}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Label x:Name="LblFileName"
                   Content="{Binding LblFileNameContent}"
                   Padding="0 2"
                   IsVisible="{Binding IsLblFileNameVisible}"
                   VerticalAlignment="Center"
                   FontSize="14" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="10"
                    Margin="0,0,20,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
            <ComboBox x:Name="CmbSaveTarget"
                      MinWidth="120"
                      VerticalAlignment="Center"
                      CornerRadius="6"
                      ToolTip.Tip="{Binding SaveTargetHint}"
                      ItemsSource="{Binding SaveTargetOptions}"
                      IsVisible="{Binding IsCmbSaveTargetVisible}"
                      SelectedItem="{Binding SelectedSaveTargetOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:MainWindowViewModel+SaveTargetOption">
                        <TextBlock Text="{Binding Content}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button x:Name="BtnSaveFile"
                    Padding="5 2"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    IsVisible="{Binding IsBtnSaveFileVisible}"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Classes="outline-button"
                    Height="30"
                    ToolTip.Tip="{Binding SaveFileHint}"
                    Command="{Binding BtnSaveFileCommand}">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <!-- <controls:SymbolIcon Symbol="SaveAs" FontSize="20" /> -->
                    <TextBlock Classes="icon-font" Text="{x:Static local:Icons.SaveAs}" />
                    <TextBlock Text="{Binding BtnSaveAsContent}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
            <Button x:Name="BtnExit"
                    Padding="5 2"
                    Width="50"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Classes="outline-button danger-outline-button"
                    Height="30"
                    ToolTip.Tip="{Binding ExitHint}"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Click="BtnExit_Click">
                <TextBlock Classes="icon-font" Text="{x:Static local:Icons.PowerButton}" FontWeight="SemiBold" />
            </Button>
        </StackPanel>
        <StackPanel x:Name="StbStatusBar" Grid.Row="3" Height="30">
            <Label x:Name="LblStatusBar" Content="{Binding LblStatusBarContent}" Padding="0 2" Margin="10,0,0,0"
                   HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="14" />
        </StackPanel>
    </Grid>

    <!--<TextBlock Text="{Binding Greeting}" HorizontalAlignment="Center" VerticalAlignment="Center"/>-->

</Window>